<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark Theme Colors (Default) -->
    <Color x:Key="BgColor">#0F0F14</Color>
    <Color x:Key="SurfaceColor">#18181F</Color>
    <Color x:Key="SurfaceRaisedColor">#1E1E27</Color>
    <Color x:Key="SurfaceHoverColor">#252530</Color>
    <Color x:Key="TextColor">#EAEAEF</Color>
    <Color x:Key="TextMutedColor">#6E7185</Color>
    <Color x:Key="TextDimColor">#4A4C5E</Color>
    <Color x:Key="BorderColor">#1A1A24</Color>

    <Color x:Key="AccentColor">#0EA5A9</Color>
    <Color x:Key="AccentHoverColor">#0CBBC0</Color>
    <Color x:Key="AccentSubtleColor">#1A2A2B</Color>

    <Color x:Key="SuccessColor">#34D399</Color>
    <Color x:Key="WarningColor">#FBBF24</Color>
    <Color x:Key="DangerColor">#F87171</Color>
    <Color x:Key="InfoColor">#60A5FA</Color>

    <!-- File type category colors -->
    <Color x:Key="RevitColor">#4F8EF7</Color>
    <Color x:Key="BlenderColor">#F5A623</Color>
    <Color x:Key="CadColor">#A78BFA</Color>
    <Color x:Key="ImageColor">#F472B6</Color>
    <Color x:Key="DocumentColor">#34D399</Color>
    <Color x:Key="InstallerColor">#FB923C</Color>
    <Color x:Key="WebLinkColor">#60A5FA</Color>
    <Color x:Key="ArchiveColor">#94A3B8</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="{StaticResource SurfaceRaisedColor}"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource SurfaceHoverColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource TextDimColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentSubtleBrush" Color="{StaticResource AccentSubtleColor}"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

    <SolidColorBrush x:Key="RevitBrush" Color="{StaticResource RevitColor}"/>
    <SolidColorBrush x:Key="BlenderBrush" Color="{StaticResource BlenderColor}"/>
    <SolidColorBrush x:Key="CadBrush" Color="{StaticResource CadColor}"/>
    <SolidColorBrush x:Key="ImageBrush" Color="{StaticResource ImageColor}"/>
    <SolidColorBrush x:Key="DocumentBrush" Color="{StaticResource DocumentColor}"/>
    <SolidColorBrush x:Key="InstallerBrush" Color="{StaticResource InstallerColor}"/>
    <SolidColorBrush x:Key="WebLinkBrush" Color="{StaticResource WebLinkColor}"/>
    <SolidColorBrush x:Key="ArchiveBrush" Color="{StaticResource ArchiveColor}"/>

</ResourceDictionary>
