<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light Theme Colors -->
    <Color x:Key="BgColor">#F3F4F6</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="SurfaceRaisedColor">#F9FAFB</Color>
    <Color x:Key="SurfaceHoverColor">#EEF0F3</Color>
    <Color x:Key="TextColor">#111827</Color>
    <Color x:Key="TextMutedColor">#6B7280</Color>
    <Color x:Key="TextDimColor">#9CA3AF</Color>
    <Color x:Key="BorderColor">#E5E7EB</Color>

    <Color x:Key="AccentColor">#0D9498</Color>
    <Color x:Key="AccentHoverColor">#0BA8AD</Color>
    <Color x:Key="AccentSubtleColor">#E6F7F7</Color>

    <Color x:Key="SuccessColor">#059669</Color>
    <Color x:Key="WarningColor">#D97706</Color>
    <Color x:Key="DangerColor">#DC2626</Color>
    <Color x:Key="InfoColor">#2563EB</Color>

    <!-- File type category colors -->
    <Color x:Key="RevitColor">#3B72D9</Color>
    <Color x:Key="BlenderColor">#D9900E</Color>
    <Color x:Key="CadColor">#7C5CCC</Color>
    <Color x:Key="ImageColor">#D946A8</Color>
    <Color x:Key="DocumentColor">#059669</Color>
    <Color x:Key="InstallerColor">#E07416</Color>
    <Color x:Key="WebLinkColor">#2563EB</Color>
    <Color x:Key="ArchiveColor">#64748B</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="{StaticResource SurfaceRaisedColor}"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource SurfaceHoverColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource TextDimColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentSubtleBrush" Color="{StaticResource AccentSubtleColor}"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

    <SolidColorBrush x:Key="RevitBrush" Color="{StaticResource RevitColor}"/>
    <SolidColorBrush x:Key="BlenderBrush" Color="{StaticResource BlenderColor}"/>
    <SolidColorBrush x:Key="CadBrush" Color="{StaticResource CadColor}"/>
    <SolidColorBrush x:Key="ImageBrush" Color="{StaticResource ImageColor}"/>
    <SolidColorBrush x:Key="DocumentBrush" Color="{StaticResource DocumentColor}"/>
    <SolidColorBrush x:Key="InstallerBrush" Color="{StaticResource InstallerColor}"/>
    <SolidColorBrush x:Key="WebLinkBrush" Color="{StaticResource WebLinkColor}"/>
    <SolidColorBrush x:Key="ArchiveBrush" Color="{StaticResource ArchiveColor}"/>

</ResourceDictionary>
